# .env.example → 복사 후 .env.local로 사용
# cp .env.example .env.local
# .env.local은 .gitignore에 포함됨

# ── Kafka ─────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC_TELEMETRY_RAW=telemetry-raw
KAFKA_TOPIC_TELEMETRY_PROCESSED=telemetry-processed
KAFKA_TOPIC_ALERT_EVENTS=alert-events
KAFKA_TOPIC_LEGACY_SYNC_QUEUE=legacy-sync-queue
KAFKA_TOPIC_DEAD_LETTER=dead-letter-topic

# ── DynamoDB Local ────────────────────────────────
DYNAMODB_TABLE_NAME=battery-telemetry
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# ── RDS (Local PostgreSQL) ────────────────────────
RDS_ENDPOINT=postgres
RDS_DB_NAME=glovis_poc
RDS_USERNAME=glovis_admin
RDS_PASSWORD=local_password
RDS_SECRET_ARN=local

# ── IoT API Key (로컬: 실제 검증 없이 고정값 사용) ─
IOT_API_KEY_SECRET_ARN=local
IOT_API_KEY=local-dev-api-key

# ── Legacy API (로컬: Mock) ───────────────────────
LEGACY_API_BASE_URL=http://mock-legacy-api:8090
