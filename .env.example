# .env.example → 복사 후 .env.local로 사용
# cp .env.example .env.local
# .env.local은 .gitignore에 포함됨

# ── Kafka (로컬: docker-compose 내부 / Azure: Event Hubs) ─────
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC_TELEMETRY_RAW=telemetry-raw
KAFKA_TOPIC_TELEMETRY_PROCESSED=telemetry-processed
KAFKA_TOPIC_ALERT_EVENTS=alert-events
KAFKA_TOPIC_LEGACY_SYNC_QUEUE=legacy-sync-queue
KAFKA_TOPIC_DEAD_LETTER=dead-letter-topic
# Azure Event Hubs 사용 시 아래 값으로 교체
# KAFKA_BOOTSTRAP_SERVERS={namespace}.servicebus.windows.net:9093
# KAFKA_SECURITY_PROTOCOL=SASL_SSL
# KAFKA_SASL_MECHANISM=PLAIN
# KAFKA_SASL_JAAS_CONFIG=org.apache.kafka.common.security.plain.PlainLoginModule required username="$ConnectionString" password="{connection_string}";

# ── Azure Cosmos DB (로컬: Emulator / Azure: 실제 Cosmos DB) ──
COSMOS_ENDPOINT=https://cosmosdb-emulator:8081
COSMOS_KEY=C2y6yDjf5/R+ob0N8A7Cgv30VRDJIWEHLM+4QDU5DE2nQ9nDuVTqobD4b8mGGyPMbIZnqyMsEcaGQy67XIw/Jw==
COSMOS_DATABASE=battery-poc
COSMOS_CONTAINER=battery-telemetry
# Azure 실제 환경 사용 시 아래 값으로 교체
# COSMOS_ENDPOINT=https://{account}.documents.azure.com:443/
# COSMOS_KEY={primary_key}

# ── PostgreSQL (로컬: docker-compose / Azure: Flexible Server) ─
RDS_ENDPOINT=postgres
RDS_DB_NAME=glovis_poc
RDS_USERNAME=glovis_admin
RDS_PASSWORD=local_password
# Azure 실제 환경 사용 시 아래 값으로 교체
# RDS_ENDPOINT={server}.postgres.database.azure.com
# RDS_PASSWORD={실제_비밀번호}

# ── Azure Key Vault (로컬: 미사용 / Azure: 실제 Key Vault) ────
KEY_VAULT_URI=
# Azure 실제 환경 사용 시
# KEY_VAULT_URI=https://{vault-name}.vault.azure.net/

# ── IoT API Key ───────────────────────────────────────────────
IOT_API_KEY=local-dev-api-key

# ── Legacy API (로컬: Mock) ───────────────────────────────────
LEGACY_API_BASE_URL=http://mock-legacy-api:8090
